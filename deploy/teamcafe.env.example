# Copy to /srv/midnight/.env on the VPS (chmod 600). Generate a new DJANGO_SECRET_KEY for production.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=teamcafe.cloud,www.teamcafe.cloud
DJANGO_CSRF_TRUSTED_ORIGINS=https://teamcafe.cloud,https://www.teamcafe.cloud
DJANGO_BEHIND_PROXY=1

USE_POSTGRES=1
DB_NAME=midnight
DB_USER=midnight
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
